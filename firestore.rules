rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı fonksiyonlar ──────────────────────────────────────────────
    function girisYapti() {
      return request.auth != null;
    }

    function kokAdminMi() {
      return girisYapti() && request.auth.uid == 'sIKGnuwKj7cAMGnPvJg3BF1JWXf1';
    }

    function profilAdminMi() {
      return girisYapti() &&
        exists(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)).data.get('rol', 'denetci') == 'admin' &&
        get(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)).data.get('durum', 'aktif') == 'aktif';
    }

    function adminMi() {
      return kokAdminMi() || profilAdminMi();
    }

    function aktifKullanici() {
      // Kullanıcı oturumu açık VE Firestore'da durum:aktif VEYA eski kayıt (durum alanı yok)
      return girisYapti() && (
        adminMi() ||
        (
          exists(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)).data.get('durum', 'aktif') == 'aktif'
        )
      );
    }

    function aktifEkipUyesi(ekipId) {
      return aktifKullanici() && (
        adminMi() ||
        (
          exists(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)).data.get('ekipId', '') == ekipId
        )
      );
    }

    function kendiDenetimiMi() {
      return aktifKullanici() && (
        resource.data.get('kullaniciId', '') == request.auth.uid ||
        (
          resource.data.get('kullaniciId', '') == '' &&
          exists(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)) &&
          resource.data.get('denetciler', []).hasAny([get(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)).data.get('ad', '')])
        )
      );
    }

    // ── Kullanıcılar ──────────────────────────────────────────────────────
    match /kullanicilar/{uid} {
      // Kayıt sırasında yeni belge oluşturabilir (durum: beklemede olmalı)
      allow create: if adminMi() ||
                    (girisYapti()
                    && request.auth.uid == uid
                    && request.resource.data.durum == 'beklemede');

      // Kendi profilini okuyabilir; admin hepsini okuyabilir
      allow read: if girisYapti() && (request.auth.uid == uid || adminMi());

      // Güncelleme: admin her şeyi; kullanıcı sadece kendi ad/telefon/cihaz bilgisini
      allow update: if adminMi() ||
                    (girisYapti() && request.auth.uid == uid &&
                     request.resource.data.durum == resource.data.durum &&  // durumu değiştiremez
                     request.resource.data.rol   == resource.data.rol);     // rolü değiştiremez

      allow delete: if adminMi();
    }

    // ── Denetimler ────────────────────────────────────────────────────────
    match /denetimler/{docId} {
      allow read:   if aktifKullanici();
      allow create: if aktifKullanici();
      allow update: if aktifKullanici();
      allow delete: if adminMi() || kendiDenetimiMi();
    }

    // ── İşletmeler master ─────────────────────────────────────────────────
    match /isletmeler_master/{docId} {
      allow read:   if aktifKullanici();
      allow write:  if aktifKullanici();   // konum ekleme vb. için
    }

    // ── Planlanan denetimler ──────────────────────────────────────────────
    match /planlanan_denetimler/{uid} {
      allow read:   if girisYapti() && (request.auth.uid == uid || adminMi());
      allow write:  if girisYapti() && (request.auth.uid == uid || adminMi());
    }
    match /planlanan_denetimler/{uid}/{docId} {
      allow read:   if girisYapti() && (request.auth.uid == uid || adminMi());
      allow write:  if girisYapti() && (request.auth.uid == uid || adminMi());
    }
    match /planlanan_denetimler_ekip/{ekipId} {
      allow read:   if aktifEkipUyesi(ekipId);
      allow write:  if aktifEkipUyesi(ekipId);
    }
    match /planlanan_denetimler_ekip/{ekipId}/{docId} {
      allow read:   if aktifEkipUyesi(ekipId);
      allow write:  if aktifEkipUyesi(ekipId);
    }

    // ── Aktiviteler (log) ─────────────────────────────────────────────────
    match /aktiviteler/{docId} {
      allow read:   if adminMi();
      allow create: if aktifKullanici();
      allow update, delete: if adminMi();
    }

    // ── Konum kayıtları ───────────────────────────────────────────────────
    match /konum_kayitlari/{docId} {
      allow read:   if aktifKullanici();
      allow create: if aktifKullanici();
      allow delete: if adminMi();
    }

    // ── App meta (isletme_data vb.) ───────────────────────────────────────
    match /app_meta/{docId} {
      allow read:   if aktifKullanici();
      allow write:  if adminMi();
    }

    // ── GGBS kayıtlar ────────────────────────────────────────────────────
    match /ggbs_kayitlar/{docId} {
      allow read:   if aktifKullanici();
      allow write:  if adminMi();
    }

    // ── İşletme hızlı notları ────────────────────────────────────────────
    match /isletme_hizli_notlar/{docId} {
      allow read: if aktifKullanici();
      allow create: if aktifKullanici()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.isletmeKey is string
        && request.resource.data.mesaj is string;
      allow update: if false;
      allow delete: if aktifKullanici() && resource.data.uid == request.auth.uid;
    }
    match /isletme_hizli_notlar_dev/{docId} {
      allow read: if aktifKullanici();
      allow create: if aktifKullanici()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.isletmeKey is string
        && request.resource.data.mesaj is string;
      allow update: if false;
      allow delete: if aktifKullanici() && resource.data.uid == request.auth.uid;
    }

    // ── Extra işletmeler ─────────────────────────────────────────────────
    match /extra_isletmeler/{docId} {
      allow read:   if aktifKullanici();
      allow write:  if adminMi();
    }

    // ── Sayaçlar ─────────────────────────────────────────────────────────
    match /sayaclar/{docId} {
      allow read:   if aktifKullanici();
      allow write:  if aktifKullanici();
    }

    // ── Yaptırımlar ───────────────────────────────────────────────────────
    match /yaptirimlar/{docId} {
      allow read:   if aktifKullanici();
      allow write:  if aktifKullanici();
    }

    // ── Mesajlar / İletiler (sohbet) ──────────────────────────────────────
    match /mesajlar/{docId} {
      allow read:   if aktifKullanici();
      allow create: if aktifKullanici();
      allow update, delete: if adminMi();
    }
    match /mesajlar/{docId}/iletiler/{iletiId} {
      allow read:   if aktifKullanici();
      allow create: if aktifKullanici();
      allow update, delete: if adminMi();
    }
    match /iletiler/{docId} {
      allow read:   if aktifKullanici();
      allow create: if aktifKullanici();
      allow update, delete: if adminMi();
    }

    // ── Kullanıcı sorun bildirimleri ──────────────────────────────────────
    match /sorun_bildirimleri/{docId} {
      allow read:   if adminMi() || (aktifKullanici() && resource.data.bildirenUid == request.auth.uid);
      allow create: if aktifKullanici() && (adminMi() || request.resource.data.bildirenUid == request.auth.uid);
      allow update, delete: if adminMi();
    }
    match /sorun_bildirimleri_dev/{docId} {
      allow read:   if adminMi() || (aktifKullanici() && resource.data.bildirenUid == request.auth.uid);
      allow create: if aktifKullanici() && (adminMi() || request.resource.data.bildirenUid == request.auth.uid);
      allow update, delete: if adminMi();
    }

    // ── Presence (çevrimiçi durumu) ───────────────────────────────────────
    match /presence/{uid} {
      allow read:   if aktifKullanici();
      allow write:  if girisYapti() && request.auth.uid == uid;
    }

    // ── Varsayılan: her şeyi reddet ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
